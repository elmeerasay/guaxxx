# ─────────────────────────────────────────────
#  .env — Konfigurasi AutoClaimForwardDelegate
#  Copy file ini ke .env lalu isi nilainya
# ─────────────────────────────────────────────

# BSC RPC endpoint
BSC_RPC=https://bsc-dataseed1.binance.org/

# Private key wallet deployer (0x8575846...) — yang deploy contract
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PK

# Private key wallet worker (0xe7FC147...) — yang delegate & terima BNB
WORKER_PRIVATE_KEY=0xYOUR_WORKER_PK

# Alamat penerima GUA hasil claim
RECIPIENT=0x8575846d8fdbcc9e4e346906ad51a65225912345

# Bytecode hasil compile AutoClaimForwardDelegate.sol di Remix
# Compilation Details → Bytecode → object
BYTECODE=0xPASTE_COMPILED_BYTECODE_HERE
